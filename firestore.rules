rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'ADMIN'; }
    function isVerified() { return request.auth.token.email_verified == true; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) 
        && data.uid is string && data.uid.size() <= 128
        && data.email is string && data.email.size() <= 128
        && data.role in ['ADMIN', 'KAPUS', 'SEKRETARIS', 'STAFF'];
    }

    function isValidMailIncoming(data) {
      return data.keys().hasAll(['letterNumber', 'sender', 'subject', 'status', 'createdBy'])
        && data.letterNumber is string && data.letterNumber.size() <= 100
        && data.sender is string && data.sender.size() <= 200
        && data.subject is string && data.subject.size() <= 1000
        && data.status in ['PENDING', 'DISPOSED', 'COMPLETED', 'ARCHIVED']
        && data.createdBy == request.auth.uid;
    }

    function isValidMailOutgoing(data) {
      return data.keys().hasAll(['letterNumber', 'recipient', 'subject', 'status', 'createdBy'])
        && data.letterNumber is string && data.letterNumber.size() <= 100
        && data.recipient is string && data.recipient.size() <= 200
        && data.subject is string && data.subject.size() <= 1000
        && data.status in ['DRAFT', 'SENT', 'ARCHIVED']
        && data.createdBy == request.auth.uid;
    }

    function isValidDisposition(data) {
      return data.keys().hasAll(['mailIncomingId', 'fromId', 'toId', 'instruction', 'status'])
        && isValidId(data.mailIncomingId)
        && data.fromId == request.auth.uid
        && isValidId(data.toId)
        && data.instruction is string && data.instruction.size() <= 2000
        && data.status in ['PENDING', 'READ', 'COMPLETED'];
    }

    // --- Collection Routes ---

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && (incoming().role == existing().role || isAdmin()); // Only admin can change role
    }

    match /mailsIncoming/{mailId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMailIncoming(incoming());
      allow update: if isSignedIn() && isValidMailIncoming(incoming())
        && (incoming().createdBy == existing().createdBy || isAdmin());
    }

    match /mailsOutgoing/{mailId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMailOutgoing(incoming());
      allow update: if isSignedIn() && isValidMailOutgoing(incoming())
        && (incoming().createdBy == existing().createdBy || isAdmin());
    }

    match /dispositions/{dispositionId} {
      allow get: if isSignedIn() && (isOwner(existing().fromId) || isOwner(existing().toId) || isAdmin());
      allow list: if isSignedIn(); // Queries must filter by toId or fromId
      allow create: if isSignedIn() && isValidDisposition(incoming());
      allow update: if isSignedIn() && isValidDisposition(incoming())
        && (isOwner(existing().fromId) || isOwner(existing().toId) || isAdmin());
    }

    match /notifications/{notificationId} {
      allow get: if isOwner(existing().userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Any user can send a notification to another (e.g. on disposition)
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
